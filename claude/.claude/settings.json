{
  "model": "opus",
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeCoAuthoredBy": false,
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/context-warn.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/dotfiles-uncommitted-warn.py",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "effortLevel": "xhigh",
  "theme": "dark",
  "autoCompactEnabled": false
}
